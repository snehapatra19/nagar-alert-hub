# ═══════════════════════════════════════════════
# Nagar Alert Hub — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════

# Flask
FLASK_ENV=production
SECRET_KEY=your-super-secret-key-change-this-in-production

# Google Maps API Key (get from console.cloud.google.com)
# Enable: Maps JavaScript API, Geocoding API, Places API
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE

# Database (SQLite default, or use PostgreSQL for production)
# DATABASE_URL=postgresql://user:password@host:5432/nagar_alert_hub

# Port
PORT=5000
