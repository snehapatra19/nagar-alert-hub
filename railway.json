{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "python models/train_model.py && gunicorn app:app --workers=2 --timeout=120 --bind=0.0.0.0:$PORT",
    "healthcheckPath": "/api/stats",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
